# Google service account JSON file. Keep the real file outside Git.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# NASTAVNYK_COMMAND_CENTER
GOOGLE_SHEETS_ID=1PzikJ_rpFJx4SHOAroE0w9-X7eclEgA6IpmExSTEs_4

# GA4 property id, numbers only.
GA4_PROPERTY_ID=

# Optional: event name used for student/tutor registration in GA4.
GA4_REGISTRATION_EVENT_NAME=sign_up

# Optional: how many completed days to collect when no dates are passed.
GA4_LOOKBACK_DAYS=1

# Meta / Instagram. Fill after Meta API setup.
META_GRAPH_VERSION=v25.0
META_ACCOUNT_INSIGHT_METRICS=reach,views,follower_count,profile_views,website_clicks
META_MEDIA_INSIGHT_METRICS=reach,views,likes,comments,saved,shares
META_MEDIA_LIMIT=25
META_LOOKBACK_DAYS=1
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=

# TikTok Display API. Fill after TikTok Developer app + OAuth setup.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats,video.list
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_TOKEN_EXPIRES_AT=
TIKTOK_REFRESH_EXPIRES_AT=
TIKTOK_USER_FIELDS=open_id,union_id,avatar_url,display_name,username,follower_count,following_count,likes_count,video_count
TIKTOK_VIDEO_FIELDS=id,create_time,share_url,embed_link,title,video_description,duration,view_count,like_count,comment_count,share_count
TIKTOK_VIDEO_LIMIT=40
TIKTOK_LOOKBACK_DAYS=1
